{
  "$schema": "https://styledictionary.com/reference/config/",
  "description": "Safari Ops Mobile – Design Tokens (Token Studio / Style Dictionary format)",
  "global": {
    "color": {
      "brand": {
        "primary":     { "$value": "#3B82F6", "$type": "color", "description": "Primary blue – nav, buttons, active states" },
        "primaryLight":{ "$value": "#60A5FA", "$type": "color", "description": "Primary blue hover" },
        "primaryDark": { "$value": "#2563EB", "$type": "color", "description": "Primary blue pressed" }
      },
      "status": {
        "success": { "$value": "#10B981", "$type": "color", "description": "Available / Success / Income" },
        "warning": { "$value": "#F59E0B", "$type": "color", "description": "Maintenance / Pending" },
        "danger":  { "$value": "#EF4444", "$type": "color", "description": "Cancelled / Expense / Error" },
        "accent":  { "$value": "#9333EA", "$type": "color", "description": "Rented / Purple accent" }
      },
      "booking": {
        "confirmed":  { "$value": "#3B82F6", "$type": "color" },
        "inProgress": { "$value": "#10B981", "$type": "color" },
        "completed":  { "$value": "#6B7280", "$type": "color" },
        "pending":    { "$value": "#F59E0B", "$type": "color" },
        "cancelled":  { "$value": "#EF4444", "$type": "color" }
      },
      "fleet": {
        "available":    { "$value": "#10B981", "$type": "color" },
        "booked":       { "$value": "#3B82F6", "$type": "color" },
        "rented":       { "$value": "#9333EA", "$type": "color" },
        "maintenance":  { "$value": "#F59E0B", "$type": "color" },
        "outOfService": { "$value": "#EF4444", "$type": "color" }
      },
      "background": {
        "app":    { "$value": "#F3F4F6", "$type": "color", "description": "Screen background" },
        "card":   { "$value": "#FFFFFF", "$type": "color", "description": "Card / surface" },
        "border": { "$value": "#E5E7EB", "$type": "color", "description": "Dividers and borders" }
      },
      "text": {
        "primary": { "$value": "#111827", "$type": "color" },
        "muted":   { "$value": "#6B7280", "$type": "color" },
        "light":   { "$value": "#9CA3AF", "$type": "color" }
      }
    },
    "typography": {
      "fontFamily": {
        "base": { "$value": "SF Pro Display, Roboto, system-ui, sans-serif", "$type": "fontFamily" }
      },
      "fontSize": {
        "caption": { "$value": "12", "$type": "dimension" },
        "label":   { "$value": "13", "$type": "dimension" },
        "body":    { "$value": "15", "$type": "dimension" },
        "title":   { "$value": "16", "$type": "dimension" },
        "h3":      { "$value": "18", "$type": "dimension" },
        "h2":      { "$value": "22", "$type": "dimension" },
        "h1":      { "$value": "28", "$type": "dimension" },
        "kpi":     { "$value": "26", "$type": "dimension" }
      },
      "fontWeight": {
        "regular":   { "$value": "400", "$type": "fontWeight" },
        "medium":    { "$value": "500", "$type": "fontWeight" },
        "semiBold":  { "$value": "600", "$type": "fontWeight" },
        "bold":      { "$value": "700", "$type": "fontWeight" }
      },
      "lineHeight": {
        "tight":   { "$value": "1.2", "$type": "lineHeight" },
        "base":    { "$value": "1.4", "$type": "lineHeight" },
        "relaxed": { "$value": "1.6", "$type": "lineHeight" }
      }
    },
    "spacing": {
      "xs":      { "$value": "4",  "$type": "spacing" },
      "sm":      { "$value": "8",  "$type": "spacing" },
      "md":      { "$value": "12", "$type": "spacing" },
      "lg":      { "$value": "16", "$type": "spacing" },
      "xl":      { "$value": "20", "$type": "spacing" },
      "xxl":     { "$value": "24", "$type": "spacing" },
      "section": { "$value": "32", "$type": "spacing" }
    },
    "borderRadius": {
      "card":   { "$value": "12", "$type": "borderRadius" },
      "badge":  { "$value": "8",  "$type": "borderRadius" },
      "input":  { "$value": "8",  "$type": "borderRadius" },
      "button": { "$value": "10", "$type": "borderRadius" },
      "modal":  { "$value": "24", "$type": "borderRadius" },
      "full":   { "$value": "999","$type": "borderRadius" }
    },
    "shadow": {
      "card": {
        "color":  { "$value": "rgba(0,0,0,0.07)", "$type": "color" },
        "x":      { "$value": "0",  "$type": "dimension" },
        "y":      { "$value": "2",  "$type": "dimension" },
        "blur":   { "$value": "6",  "$type": "dimension" },
        "spread": { "$value": "0",  "$type": "dimension" }
      },
      "modal": {
        "color":  { "$value": "rgba(0,0,0,0.12)", "$type": "color" },
        "x":      { "$value": "0",  "$type": "dimension" },
        "y":      { "$value": "4",  "$type": "dimension" },
        "blur":   { "$value": "16", "$type": "dimension" },
        "spread": { "$value": "0",  "$type": "dimension" }
      }
    },
    "size": {
      "inputHeight":  { "$value": "48",  "$type": "dimension" },
      "buttonHeight": { "$value": "50",  "$type": "dimension" },
      "iconSm":       { "$value": "16",  "$type": "dimension" },
      "iconMd":       { "$value": "20",  "$type": "dimension" },
      "iconLg":       { "$value": "24",  "$type": "dimension" },
      "avatarSm":     { "$value": "40",  "$type": "dimension" },
      "avatarLg":     { "$value": "64",  "$type": "dimension" },
      "kpiCard":      { "$value": "160", "$type": "dimension" }
    }
  }
}
